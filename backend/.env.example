# Local portfolio demo. Set to 0 only when you have live service credentials.
MOCK_SERVICES=1
APP_ENV=local

# Public frontend origin for CORS and generated links.
PUBLIC_APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# Gemini Live/text models. Keys are optional in mock mode.
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite

# OpenAI structured-output judge/report helpers. Key is optional in mock mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Firebase Admin/Storage. Required only for live uploads/logging.
FIREBASE_KEY_PATH=./firebase_key.json
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Retrieval backend. Use chroma for local/live single-instance runs.
RAG_BACKEND=chroma
